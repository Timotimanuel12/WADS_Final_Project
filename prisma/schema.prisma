generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String?        @db.Text
  displayName  String?       @db.Text
  username      String?        @unique @db.Text
  firstName     String?        @db.Text
  lastName      String?        @db.Text
  university    String?        @db.Text
  major         String?        @db.Text
  profilePhotoUrl String?      @db.Text
  profileCompleted Boolean     @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tasks         Task[]
  focusSessions FocusSession[]
}

model Task {
  id          String      @id @default(uuid())
  userId      String
  title       String      @db.Text
  description String      @db.Text @default("")
  status      String      @db.Text @default("pending")
  priority    String      @db.Text @default("medium")
  category    String      @db.Text @default("")
  course      String      @db.Text @default("")
  taskLink    String?     @db.Text
  attachmentName String?  @db.Text
  attachmentMimeType String? @db.Text
  attachmentDataUrl String? @db.Text
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, updatedAt])
}

model FocusSession {
  id              String    @id @default(uuid())
  userId          String
  taskId          String?
  durationMinutes Int
  startedAt       DateTime
  completedAt     DateTime
  notes           String    @db.Text @default("")
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([userId, completedAt])
}

